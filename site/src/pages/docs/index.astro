---
import DocsLayout from '../../layouts/DocsLayout.astro';
---

<DocsLayout title="Documentation" section="">
  <div class="docs-home">
    <p class="docs-lead">Everything you need to build on, operate, and understand the UltraDAG network.</p>

    <div class="docs-grid">
      <a href="/docs/getting-started/quickstart" class="docs-card">
        <div class="docs-card-icon">&#9889;</div>
        <h3>Quick Start</h3>
        <p>Download, build, and run your first UltraDAG node in under 5 minutes.</p>
      </a>
      <a href="/docs/architecture/overview" class="docs-card">
        <div class="docs-card-icon">&#9881;</div>
        <h3>Architecture</h3>
        <p>Understand DAG-BFT consensus, the state engine, and P2P networking.</p>
      </a>
      <a href="/docs/api/rpc" class="docs-card">
        <div class="docs-card-icon">&#128268;</div>
        <h3>API Reference</h3>
        <p>Complete HTTP RPC endpoint reference with curl examples.</p>
      </a>
      <a href="/docs/operations/node-guide" class="docs-card">
        <div class="docs-card-icon">&#128421;</div>
        <h3>Node Operations</h3>
        <p>Production deployment, monitoring, backups, and upgrades.</p>
      </a>
      <a href="/docs/tokenomics/supply" class="docs-card">
        <div class="docs-card-icon">&#9878;</div>
        <h3>Tokenomics</h3>
        <p>Supply, emission schedule, staking, delegation, and governance.</p>
      </a>
      <a href="/docs/security/model" class="docs-card">
        <div class="docs-card-icon">&#128274;</div>
        <h3>Security</h3>
        <p>Cryptographic primitives, BFT model, audits, and bug bounty.</p>
      </a>
      <a href="/docs/technical/formal-verification" class="docs-card">
        <div class="docs-card-icon">&#128300;</div>
        <h3>Technical Deep Dives</h3>
        <p>TLA+ verification, checkpoint protocol, Noise encryption, simulation.</p>
      </a>
      <a href="/docs/api/sdks" class="docs-card">
        <div class="docs-card-icon">&#128230;</div>
        <h3>SDKs</h3>
        <p>Python, JavaScript, Rust, and Go client libraries.</p>
      </a>
    </div>

    <div class="docs-quick-links">
      <h2>Quick Links</h2>
      <div class="quick-links-grid">
        <div class="quick-links-col">
          <h4>Popular</h4>
          <ul>
            <li><a href="/docs/getting-started/quickstart">Quick Start Guide</a></li>
            <li><a href="/docs/api/rpc">RPC API Reference</a></li>
            <li><a href="/docs/getting-started/validator">Run a Validator</a></li>
            <li><a href="/docs/api/sdks">SDK Documentation</a></li>
          </ul>
        </div>
        <div class="quick-links-col">
          <h4>Understand</h4>
          <ul>
            <li><a href="/docs/architecture/consensus">DAG-BFT Consensus</a></li>
            <li><a href="/docs/tokenomics/supply">Emission Schedule</a></li>
            <li><a href="/docs/tokenomics/governance">Council of 21</a></li>
            <li><a href="/docs/technical/checkpoints">Checkpoint Protocol</a></li>
          </ul>
        </div>
        <div class="quick-links-col">
          <h4>Operate</h4>
          <ul>
            <li><a href="/docs/operations/validator-handbook">Validator Handbook</a></li>
            <li><a href="/docs/operations/monitoring">Monitoring & Alerts</a></li>
            <li><a href="/docs/operations/cli">CLI Reference</a></li>
            <li><a href="/docs/getting-started/docker">Docker Deployment</a></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="docs-testnet-cta">
      <h3>Live Testnet</h3>
      <p>The public testnet is live. Connect to any of the 5 nodes:</p>
      <pre><code>curl https://ultradag-node-1.fly.dev/status | jq .</code></pre>
      <div class="docs-cta-buttons">
        <a href="/testnet" class="btn-primary">Testnet Hub</a>
        <a href="/docs/getting-started/quickstart" class="btn-secondary">Get Started</a>
      </div>
    </div>
  </div>
</DocsLayout>

<style>
  .docs-lead{
    font-size:18px;
    color:var(--subtle);
    margin-bottom:40px;
    line-height:1.7;
  }
  .docs-grid{
    display:grid;
    grid-template-columns:repeat(auto-fill,minmax(240px,1fr));
    gap:16px;
    margin-bottom:56px;
  }
  .docs-card{
    background:var(--bg2);
    border:1px solid var(--border);
    border-radius:8px;
    padding:24px;
    text-decoration:none;
    transition:border-color .2s,transform .2s;
  }
  .docs-card:hover{
    border-color:var(--accent);
    transform:translateY(-2px);
  }
  .docs-card-icon{
    font-size:24px;
    margin-bottom:12px;
  }
  .docs-card h3{
    font-family:'Syne',sans-serif;
    font-size:16px;
    font-weight:700;
    color:var(--white);
    margin-bottom:8px;
  }
  .docs-card p{
    font-size:13px;
    color:var(--subtle);
    line-height:1.6;
  }
  .docs-quick-links{margin-bottom:56px}
  .docs-quick-links h2{
    font-family:'Syne',sans-serif;
    font-size:24px;
    font-weight:700;
    color:var(--white);
    margin-bottom:24px;
    padding-bottom:8px;
    border-bottom:1px solid var(--border);
  }
  .quick-links-grid{
    display:grid;
    grid-template-columns:repeat(3,1fr);
    gap:32px;
  }
  .quick-links-col h4{
    font-family:'DM Mono',monospace;
    font-size:10px;
    font-weight:600;
    letter-spacing:.12em;
    text-transform:uppercase;
    color:var(--muted);
    margin-bottom:12px;
  }
  .quick-links-col ul{list-style:none}
  .quick-links-col li{margin-bottom:8px}
  .quick-links-col a{
    font-size:14px;
    color:var(--subtle);
    transition:color .2s;
  }
  .quick-links-col a:hover{color:var(--white)}
  .docs-testnet-cta{
    background:var(--bg2);
    border:1px solid var(--border);
    border-radius:8px;
    padding:32px;
  }
  .docs-testnet-cta h3{
    font-family:'Syne',sans-serif;
    font-size:20px;
    font-weight:700;
    color:var(--white);
    margin-bottom:8px;
  }
  .docs-testnet-cta p{
    color:var(--subtle);
    margin-bottom:16px;
  }
  .docs-testnet-cta pre{
    background:var(--bg);
    border:1px solid var(--border);
    border-radius:6px;
    padding:12px 16px;
    margin-bottom:20px;
    overflow-x:auto;
  }
  .docs-testnet-cta code{
    font-family:'DM Mono',monospace;
    font-size:13px;
    color:var(--accent);
  }
  .docs-cta-buttons{display:flex;gap:12px}
  .btn-primary{
    background:var(--accent);
    color:var(--bg);
    padding:10px 24px;
    border-radius:4px;
    font-family:'DM Mono',monospace;
    font-size:13px;
    font-weight:500;
    transition:transform .2s,box-shadow .2s;
  }
  .btn-primary:hover{
    color:var(--bg);
    transform:translateY(-1px);
    box-shadow:0 4px 16px rgba(61,155,233,.3);
  }
  .btn-secondary{
    background:transparent;
    color:var(--accent);
    padding:10px 24px;
    border-radius:4px;
    border:1px solid var(--accent);
    font-family:'DM Mono',monospace;
    font-size:13px;
    font-weight:500;
    transition:background .2s;
  }
  .btn-secondary:hover{
    background:var(--glow);
    color:var(--accent);
  }
  @media(max-width:768px){
    .quick-links-grid{grid-template-columns:1fr}
    .docs-grid{grid-template-columns:1fr 1fr}
  }
  @media(max-width:480px){
    .docs-grid{grid-template-columns:1fr}
  }
</style>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
---

<BaseLayout title="404 — Page Not Found | UltraDAG ($UDAG)">
  <section class="error-page">
    <div class="error-eyebrow reveal"><span class="line"></span>Error 404<span class="line"></span></div>
    <div class="error-code reveal">4<span class="zero">0</span>4</div>
    <h1 class="error-title reveal">Page not found</h1>
    <p class="error-body reveal">The vertex you requested doesn't exist in the DAG. It may have been pruned, or it never existed at all.</p>
    <div class="error-actions reveal">
      <a href="/" class="btn-primary">Back to home</a>
      <a href="/docs" class="btn-secondary">Documentation</a>
    </div>
  </section>
</BaseLayout>

<style>
  .error-page{
    min-height:100vh;
    display:flex;
    flex-direction:column;
    align-items:center;
    justify-content:center;
    text-align:center;
    padding:0 24px;
    position:relative;
    z-index:1;
  }
  .error-eyebrow{
    font-family:'DM Mono',monospace;
    font-size:11px;
    font-weight:600;
    letter-spacing:.15em;
    text-transform:uppercase;
    color:var(--muted);
    display:flex;
    align-items:center;
    gap:16px;
    margin-bottom:32px;
  }
  .line{
    width:40px;
    height:1px;
    background:var(--border2);
  }
  .error-code{
    font-family:'Cormorant',serif;
    font-size:140px;
    font-weight:300;
    color:var(--white);
    line-height:1;
    margin-bottom:16px;
    letter-spacing:-4px;
  }
  .zero{
    color:var(--accent);
    font-style:italic;
  }
  .error-title{
    font-family:'Syne',sans-serif;
    font-size:28px;
    font-weight:700;
    color:var(--white);
    margin-bottom:16px;
  }
  .error-body{
    font-size:16px;
    color:var(--subtle);
    max-width:440px;
    line-height:1.7;
    margin-bottom:40px;
  }
  .error-actions{
    display:flex;
    gap:16px;
  }
  .btn-primary{
    background:var(--accent);
    color:var(--bg);
    padding:12px 28px;
    border-radius:4px;
    font-family:'DM Mono',monospace;
    font-size:13px;
    font-weight:500;
    transition:transform .2s,box-shadow .2s;
  }
  .btn-primary:hover{
    color:var(--bg);
    transform:translateY(-2px);
    box-shadow:0 4px 20px rgba(61,155,233,.3);
  }
  .btn-secondary{
    color:var(--accent);
    padding:12px 28px;
    border-radius:4px;
    border:1px solid rgba(61,155,233,.3);
    font-family:'DM Mono',monospace;
    font-size:13px;
    font-weight:500;
    transition:background .2s;
  }
  .btn-secondary:hover{background:var(--glow);color:var(--accent)}

  /* Staggered reveal animations */
  .reveal{
    opacity:0;
    transform:translateY(20px);
    animation:fadeUp .6s ease forwards;
  }
  .reveal:nth-child(1){animation-delay:.1s}
  .reveal:nth-child(2){animation-delay:.2s}
  .reveal:nth-child(3){animation-delay:.3s}
  .reveal:nth-child(4){animation-delay:.4s}
  .reveal:nth-child(5){animation-delay:.5s}

  @keyframes fadeUp{
    to{opacity:1;transform:translateY(0)}
  }

  @media(max-width:600px){
    .error-code{font-size:100px}
    .error-title{font-size:22px}
    .error-actions{flex-direction:column}
  }
</style>

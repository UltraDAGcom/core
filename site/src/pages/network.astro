---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/network.css';
---

<BaseLayout title="Live Network — UltraDAG ($UDAG)" description="Monitor the UltraDAG network in real-time. View validators, consensus health, mempool, and node status.">
  
  <div class="page">
    <div class="page-inner">
      <div class="status-banner">
        <div class="status-left">
          <div class="live-dot-wrap">
            <div class="live-dot" id="live-dot"></div>
            <span class="live-label" id="live-label">CONNECTING</span>
          </div>
          <div class="net-switch">
            <button class="net-btn" id="btn-mainnet">Mainnet</button>
            <button class="net-btn active" id="btn-testnet">Testnet</button>
          </div>
          <div>
            <div class="round-big" id="dag-round">--</div>
            <div class="round-label">DAG Round</div>
          </div>
        </div>
        <div class="status-right">
          <div class="lag-badge">
            <div class="dot" id="lag-dot"></div>
            <span id="lag-text">Finality lag: --</span>
          </div>
          <div class="refresh-ring"><svg width="28" height="28"><circle class="track" cx="14" cy="14" r="12"/><circle class="progress" id="refresh-arc" cx="14" cy="14" r="12"/></svg></div>
        </div>
      </div>

      <div class="sh">Network Vitals</div>
      <div class="vitals">
        <div class="vital"><div class="vital-label">DAG Round</div><div class="vital-value" id="v-round">--</div><div class="vital-sub" id="v-round-sub">loading</div></div>
        <div class="vital"><div class="vital-label">Finalized Round</div><div class="vital-value" id="v-fin">--</div><div class="vital-sub" id="v-fin-sub">--</div></div>
        <div class="vital"><div class="vital-label">Total Supply</div><div class="vital-value" id="v-supply">--</div><div class="vital-sub" id="v-supply-sub">--</div><div class="supply-bar"><div class="supply-bar-fill" id="supply-fill"></div></div></div>
        <div class="vital"><div class="vital-label">Treasury</div><div class="vital-value" id="v-treasury">--</div><div class="vital-sub">DAO treasury</div></div>
        <div class="vital"><div class="vital-label">DAG Vertices</div><div class="vital-value" id="v-verts">--</div><div class="vital-sub">total vertices</div></div>
        <div class="vital"><div class="vital-label">Validators</div><div class="vital-value" id="v-val">--</div><div class="vital-sub">active</div></div>
        <div class="vital"><div class="vital-label">Peers</div><div class="vital-value" id="v-peers">--</div><div class="vital-sub">connected</div></div>
        <div class="vital"><div class="vital-label">Mempool</div><div class="vital-value" id="v-mem">--</div><div class="vital-sub">pending</div></div>
        <div class="vital"><div class="vital-label">Accounts</div><div class="vital-value" id="v-accts">--</div><div class="vital-sub">on-chain</div></div>
      </div>

      <div class="sh">Node Status</div>
      <div class="nodes" id="nodes"></div>

      <div class="sh">Network Health</div>
      <div class="health-grid">
        <div class="health-card"><span class="health-dot" id="h-consensus"></span><span class="health-label">Consensus</span></div>
        <div class="health-card"><span class="health-dot" id="h-p2p"></span><span class="health-label">P2P Network</span></div>
        <div class="health-card"><span class="health-dot" id="h-rpc"></span><span class="health-label">RPC API</span></div>
        <div class="health-card"><span class="health-dot" id="h-mempool"></span><span class="health-label">Mempool</span></div>
      </div>

      <div class="sh">Validators</div>
      <div class="vtable-wrap"><table class="vtable"><thead><tr><th>Validator</th><th>Stake</th><th>Commission</th><th>Status</th></tr></thead><tbody id="val-body"><tr><td colspan="4" style="text-align:center;color:var(--muted)">Loading...</td></tr></tbody></table></div>

      <div class="sh">Mempool</div>
      <div class="mempool-list" id="mempool"><div class="mp-row hdr"><span>Hash</span><span>Type</span><span>From</span><span>Fee</span></div><div class="empty-state">Loading...</div></div>
    </div>
  </div>

  <script src="../scripts/network.js"></script>
</BaseLayout>

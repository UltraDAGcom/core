---
const currentYear = new Date().getFullYear();
---

<footer class="ultradag-footer">
  <div class="udf-inner">
    <div class="udf-top">
      <div class="udf-brand">
        <div class="udf-logo">
          <img src="/media/logo/logo_website.png" alt="UltraDAG" class="nav-logo-img" style="height:40px" />
        </div>
        <p class="udf-tagline">
          The simplest production-ready DAG chain.<br />
          Fast BFT finality for machine-to-machine micropayments.
        </p>
        <div class="udf-social">
          <a href="https://github.com/UltraDAGcom/core" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
            </svg>
          </a>
          <a href="https://x.com/ultradagcom" target="_blank" rel="noopener noreferrer" aria-label="Twitter">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path>
            </svg>
          </a>
          <a href="https://t.me/ultradagcom" target="_blank" rel="noopener noreferrer" aria-label="Telegram">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="22" y1="2" x2="11" y2="13"></line>
              <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
            </svg>
          </a>
        </div>
      </div>

      <div class="udf-links-grid">
        <div class="udf-col">
          <h4>Product</h4>
          <ul>
            <li><a href="/network">Live Network</a></li>
            <li><a href="/dashboard/">Dashboard</a></li>
            <li><a href="/explorer">Block Explorer</a></li>
            <li><a href="/testnet">Testnet</a></li>
          </ul>
        </div>

        <div class="udf-col">
          <h4>Developers</h4>
          <ul>
            <li><a href="/docs">Documentation</a></li>
            <li><a href="/whitepaper">Whitepaper</a></li>
            <li><a href="https://github.com/UltraDAGcom/core" target="_blank" rel="noopener noreferrer">GitHub</a></li>
            <li><a href="/api">API Reference</a></li>
          </ul>
        </div>

        <div class="udf-col">
          <h4>Community</h4>
          <ul>
            <li><a href="/blog">Blog</a></li>
            <li><a href="https://x.com/ultradagcom" target="_blank" rel="noopener noreferrer">Twitter</a></li>
            <li><a href="https://t.me/ultradagcom" target="_blank" rel="noopener noreferrer">Telegram</a></li>
            <li><a href="/faq">FAQ</a></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="udf-bottom">
      <div class="udf-legal">
        <span>&copy; {currentYear} UltraDAG</span>
        <span class="udf-sep">|</span>
        <a href="/privacy">Privacy</a>
        <span class="udf-sep">|</span>
        <a href="/terms">Terms</a>
      </div>

      <div class="udf-status">
        <span class="udf-status-dot"></span>
        <span>Testnet Live</span>
      </div>
    </div>
  </div>
</footer>

<style>
  .ultradag-footer{
    position:relative;
    z-index:1;
    border-top:1px solid var(--border);
    background:var(--bg);
    margin-top:120px;
  }
  .udf-inner{
    max-width:1200px;
    margin:0 auto;
    padding:64px 48px 32px;
  }
  .udf-top{
    display:grid;
    grid-template-columns:1.2fr 2fr;
    gap:80px;
    margin-bottom:48px;
  }
  .udf-brand{max-width:320px}
  .udf-logo{
    display:flex;
    align-items:center;
    margin-bottom:20px;
  }
  .udf-tagline{
    font-family:'Syne',sans-serif;
    font-size:14px;
    line-height:1.7;
    color:var(--subtle);
    margin-bottom:24px;
  }
  .udf-social{
    display:flex;
    gap:16px;
  }
  .udf-social a{
    width:44px;
    height:44px;
    display:flex;
    align-items:center;
    justify-content:center;
    border:1px solid var(--border);
    border-radius:50%;
    color:var(--muted)!important;
    transition:all .2s;
    text-decoration:none!important;
  }
  .udf-social a:hover{
    border-color:var(--accent);
    color:var(--accent)!important;
    background:var(--glow2);
  }
  .udf-links-grid{
    display:grid;
    grid-template-columns:repeat(3,1fr);
    gap:40px;
  }
  .udf-col h4{
    font-family:'DM Mono',monospace;
    font-size:10px;
    font-weight:600;
    letter-spacing:.12em;
    text-transform:uppercase;
    color:var(--accent);
    margin-bottom:16px;
    padding-bottom:8px;
    border-bottom:1px solid var(--border2);
  }
  .udf-col ul{
    list-style:none;
    margin:0;
    padding:0;
    display:flex;
    flex-direction:column;
    gap:12px;
  }
  .udf-col a{
    font-family:'Syne',sans-serif;
    font-size:14px;
    color:var(--subtle)!important;
    text-decoration:none!important;
    transition:color .2s;
  }
  .udf-col a:hover{color:var(--white)!important}
  .udf-bottom{
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding-top:32px;
    border-top:1px solid var(--border);
  }
  .udf-legal{
    display:flex;
    align-items:center;
    gap:12px;
    font-family:'DM Mono',monospace;
    font-size:11px;
    color:var(--dim);
  }
  .udf-sep{color:var(--border2)}
  .udf-legal a{color:var(--subtle)}
  .udf-legal a:hover{color:var(--white)}
  .udf-status{
    display:flex;
    align-items:center;
    gap:8px;
    font-family:'DM Mono',monospace;
    font-size:11px;
    color:var(--subtle);
  }
  .udf-status-dot{
    width:8px;
    height:8px;
    border-radius:50%;
    background:var(--success);
    box-shadow:0 0 8px var(--success);
    animation:udf-pulse 2s infinite;
  }
  @keyframes udf-pulse{
    0%,100%{opacity:0.6}
    50%{opacity:1}
  }

  @media(max-width:768px){
    .udf-top{
      grid-template-columns:1fr;
      gap:32px;
    }
    .udf-links-grid{
      grid-template-columns:1fr 1fr;
    }
    .udf-inner{
      padding:40px 24px 24px;
    }
    .udf-bottom{
      flex-direction:column;
      gap:12px;
      text-align:center;
    }
    .udf-legal{
      flex-wrap:wrap;
      justify-content:center;
    }
  }
  @media(max-width:480px){
    .udf-links-grid{
      grid-template-columns:1fr;
    }
    .udf-inner{
      padding:32px 16px 20px;
    }
    .udf-tagline{
      font-size:13px;
    }
  }
</style>

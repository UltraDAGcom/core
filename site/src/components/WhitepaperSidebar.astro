<button id="sidebar-toggle" class="sidebar-toggle" aria-label="Toggle whitepaper menu">
  <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M3 5h14M3 10h14M3 15h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
  <span>Contents</span>
</button>

<aside id="docs-sidebar" class="docs-sidebar whitepaper-sidebar">
  <div class="sidebar-header">
    <a href="/whitepaper" class="sidebar-home">Whitepaper v1.1</a>
  </div>
  <nav class="sidebar-nav">
    {nav.map(group => (
      <div class="sidebar-group">
        <a href={`#${group.id}`} class="sidebar-group-title sidebar-link">{group.title}</a>
        {group.items.length > 0 && (
          <ul>
            {group.items.map(item => (
              <li>
                <a href={`#${item.id}`} class="sidebar-sublink">
                  {item.title}
                </a>
              </li>
            ))}
          </ul>
        )}
      </div>
    ))}
  </nav>
</aside>

<style>
  .whitepaper-sidebar .sidebar-group-title.sidebar-link {
    cursor: pointer;
    text-decoration: none;
    color: var(--text-secondary, #8a8f98);
    transition: color 0.2s;
    display: block;
  }
  .whitepaper-sidebar .sidebar-group-title.sidebar-link:hover {
    color: var(--accent, #3d9be9);
  }
  .whitepaper-sidebar .sidebar-group-title.sidebar-link.active {
    color: var(--accent, #3d9be9);
  }
  .whitepaper-sidebar .sidebar-sublink {
    font-size: 0.8rem;
  }
  .whitepaper-sidebar .sidebar-group {
    margin-bottom: 0.25rem;
  }
  .whitepaper-sidebar .sidebar-group ul {
    margin-bottom: 0.25rem;
  }
</style>

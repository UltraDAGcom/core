# UltraDAG Bridge — environment template
# Copy this file to .env and fill in your values.
#
# See DEPLOYMENT_GUIDE.md for the full walkthrough.

# ─── Required for deployment ─────────────────────────────────────────

# Arbitrum RPC endpoint.
# Testnet: https://sepolia-rollup.arbitrum.io/rpc
# Mainnet: https://arb1.arbitrum.io/rpc
RPC_URL=

# Deployer private key (hex, 0x-prefixed). Must be funded with ETH on
# the target chain to cover deployment gas. Treat as sensitive.
DEPLOYER_KEY=

# Governor/admin address — will own DEFAULT_ADMIN_ROLE on UDAGToken and
# be the proposer/executor on the TimelockController deployed alongside
# the token. STRONGLY recommend a Safe multisig, NOT an EOA.
GOVERNOR_ADDRESS=

# ─── Optional: IDO / presale genesis pre-mine ────────────────────────
#
# When both GENESIS_RECIPIENT and GENESIS_ALLOCATION are set, UDAGToken's
# constructor mints the allocation once, atomically, to the recipient.
# Leave unset / empty to skip the pre-mine entirely (standard bridge-only
# deployment).
#
# Hard cap: 252_000_000_000_000 sats (2,520,000 UDAG = 12% of MAX_SUPPLY).
# Amount is in 8-decimal sats: 1 UDAG = 100_000_000 sats.
#
# Full IDO bucket example:
#   GENESIS_RECIPIENT=0xYourLiquidityMultisig
#   GENESIS_ALLOCATION=252000000000000
GENESIS_RECIPIENT=
GENESIS_ALLOCATION=

# ─── Optional: contract verification ─────────────────────────────────
#
# When set, deploy-presale.sh passes --verify --etherscan-api-key to
# forge so the contracts auto-verify on Arbiscan after deployment.
ARBISCAN_API_KEY=

# ─── Filled in after deployment ──────────────────────────────────────
#
# deployment-output.json is the source of truth; these are optional
# copies for interactive shell use.
TOKEN_ADDRESS=
BRIDGE_ADDRESS=
TIMELOCK_ADDRESS=

# ─── ConfigureBridge.s.sol (post-deploy validator registration) ──────
#
# Only needed when you're ready to turn the bridge on. For a presale-
# first deployment, leave these unset — the bridge auto-enables once
# 3+ validators are registered, and registering them is a separate,
# later action (see DEPLOYMENT_GUIDE.md §1.4).
#
# GOVERNOR_KEY must be able to call addValidator() on the bridge. If
# the bridge's governor is the TimelockController (recommended), these
# calls must be scheduled through the timelock — a raw private key
# won't work on its own.
#
# VALIDATOR_ADDRESSES is a comma-separated list of the Ethereum
# addresses derived from each validator's bridge secp256k1 key (see
# crates/ultradag-coin/src/bridge/mod.rs::eth_address_from_secp_key).
# Must contain at least 3 entries before the bridge auto-enables.
GOVERNOR_KEY=
VALIDATOR_ADDRESSES=

# UltraDAG Bridge Configuration
# Copy this file to .env and fill in your values

# ===========================================
# DEPLOYMENT CONFIGURATION
# ===========================================

# Arbitrum RPC endpoint (testnet or mainnet)
# Testnet: https://sepolia-rollup.arbitrum.io/rpc
# Mainnet: https://arb1.arbitrum.io/rpc
RPC_URL=

# Deployer private key (will be deleted after deployment)
DEPLOYER_KEY=

# Governor/admin address (will own timelock after deployment)
# This should be a TimelockController address in production
GOVERNOR_KEY=

# ===========================================
# GENESIS ALLOCATIONS
# ===========================================

# Developer allocation recipient address
DEV_ADDRESS=

# Treasury allocation recipient address
TREASURY_ADDRESS=

# ===========================================
# RELAYER CONFIGURATION
# ===========================================

# 5 relayer private keys (comma-separated, no spaces)
# These will be used to derive relayer addresses
# Format: key1,key2,key3,key4,key5
RELAYER_KEYS=

# Required signatures for bridge operations (default: 3)
REQUIRED_SIGNERS=3

# ===========================================
# BRIDGE CONFIGURATION (after deployment)
# ===========================================

# Bridge contract address (filled after deployment)
BRIDGE_ADDRESS=

# Token contract address (filled after deployment)
TOKEN_ADDRESS=

# Timelock controller address (filled after deployment)
TIMELOCK_ADDRESS=

# ===========================================
# RELAYER SERVICE CONFIGURATION
# ===========================================

# UltraDAG node RPC endpoint
ULTRADAG_RPC_URL=

# Polling interval in milliseconds
POLL_INTERVAL=5000

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# ===========================================
# MONITORING CONFIGURATION
# ===========================================

# Health check port
HEALTH_CHECK_PORT=3000

# Prometheus metrics enabled (true/false)
METRICS_ENABLED=true

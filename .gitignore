/target
**/target
**/*.rs.bk
*.swp
*.swo
.DS_Store
*.json.bak
/testnet_results
/benchmark_results
/logs
nohup.out
*.log
deploy_*/

# Fly.io auto-generated files (actual configs in deployments/fly/)
fly-node-*.toml

# SDK build artifacts
sdk/python/.venv/
sdk/python/__pycache__/
sdk/python/*.egg-info/
sdk/python/.pytest_cache/
sdk/javascript/node_modules/
sdk/javascript/dist/
sdk/rust/target/
sdk/go/ultradag/testdata/
*.pyc

# TLA+ state files (can be very large)
formal/states/
.windsurf/
config/mainnet-keys.txt

# Bridge build artifacts and per-deploy outputs
bridge/cache/
bridge/out/
bridge/lib/
bridge/broadcast/
bridge/deployment-output.json
bridge/.env

# Fuzz artifacts
**/fuzz/target/
**/fuzz/corpus/
**/fuzz/artifacts/

# Backup files
*.bak
*.old
*.backup

# Dashboard build artifacts
site/dashboard/node_modules/
site/dashboard/dist/
site/dashboard/.vite/

# Site build artifacts
site/node_modules/
site/dist/
site/.vite/
site/.astro/

# MkDocs build output
mkdocs-site/site/

# Root-level Astro content-collection cache (older Astro runs dropped it here
# before we configured site/ as the working dir — don't re-track if it reappears).
/.astro/

# Stale site archives kept out of tree.
/_archives/

# Claude Code plugin settings (personal, not repo-relevant).
/.claude/

# Abandoned ESP32 experiments at the repo root. The real implementation lives
# in crates/ultradag-esp32 — anything dropped at the repo root is scratch.
/esp32-arduino/
/deploy-esp32-manual.sh
/test-esp32*.sh
/esp32-*.sh
/ESP32_*.md

# Catch-all for any node_modules anywhere in the tree. The specific
# site/node_modules/, sdk/javascript/node_modules/, etc. rules above are
# kept for clarity, but this backstop catches accidental runs of `npm`,
# `astro`, or `vite` from the wrong cwd (previously leaked a stub
# node_modules/.astro/ and node_modules/.vite/ at the repo root).
**/node_modules/
